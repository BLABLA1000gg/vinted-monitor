# Paste one or more Vinted catalog URLs, separated by |
EBAY_URL=https://www.vinted.de/catalog?search_text=iphone+13+pro

# Discord webhook for notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Seconds between polls (default: 3, set to 0 for back-to-back)
VINTED_POLL_DELAY=3

# Optional proxy — HTTP or SOCKS5
# PROXY_URL=http://user:pass@host:port
# PROXY_URL=socks5://user:pass@host:port

# Send a notification for listings already seen at startup (default: false)
NOTIFY_EXISTING=false

# Also notify when price goes up (default: false)
NOTIFY_PRICE_INCREASES=false

# Keyword filters (comma-separated)
INCLUDE_KEYWORDS=
EXCLUDE_KEYWORDS=

# Price range
MIN_PRICE=
MAX_PRICE=
CURRENCY=EUR

# SQLite database path
DATABASE_PATH=vinted_monitor.db

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
